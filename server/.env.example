# Server Configuration
PORT=5000

# MongoDB (use MongoDB Atlas for Vercel deployment)
MONGODB_URI=mongodb://localhost:27017/secure-messaging

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_EXPIRE=1h

# Encryption Key Secret (for encrypting private keys at rest)
ENCRYPTION_KEY_SECRET=your-encryption-key-secret-change-in-production-min-32-chars

# Client URL (for CORS)
CLIENT_URL=http://localhost:3000

# Set to true when deploying to Vercel
VERCEL=false
